### 系统管理 - 用户管理 API 测试

@baseUrl = http://localhost:8080
@authUrl = http://localhost:8082
@systemUrl = {{baseUrl}}/api/system

###############################################
# OAuth2 认证配置
###############################################

@clientId = jnet-client
@clientSecret = jnet-secret

